# Terraform local working directory
**/.terraform/

# Terraform state files
**/*.tfstate
**/*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Local plans
*.tfplan

# MacOS
.DS_Store
